# ============================================================
# Telegram Bot Configuration
# ============================================================
# All values below are NEXT_PUBLIC_* because the site is a static
# export — they ship in the client JS bundle. In CI they are
# injected from GitHub repo variables (not secrets) by
# .github/workflows/github-pages.yml. Locally, copy this file to
# .env.local and fill in real values.
#
# GitHub variables consumed:
#   TELEGRAM_BOT_TOKEN          -> NEXT_PUBLIC_TELEGRAM_BOT_TOKEN
#   TELEGRAM_CHAT_IDS           -> NEXT_PUBLIC_TELEGRAM_CHAT_IDS
#   CAREERS_TELEGRAM_BOT_TOKEN  -> NEXT_PUBLIC_CAREERS_TELEGRAM_BOT_TOKEN
# ============================================================

# Main bot — contact form + strategy assessment notifications
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_main_bot_token_here

# Comma-separated chat IDs that receive notifications from BOTH bots
NEXT_PUBLIC_TELEGRAM_CHAT_IDS=chat_id_1,chat_id_2

# Careers bot — receives job applications (separate bot, same chat IDs)
NEXT_PUBLIC_CAREERS_TELEGRAM_BOT_TOKEN=your_careers_bot_token_here
